{
  "name": "forge",
  "version": "1.0.0",
  "description": "Local agent orchestration platform for Claude Code",
  "keywords": [
    "claude",
    "claude-code",
    "agents",
    "orchestration",
    "developer-tools"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "forge": "./bin/forge.js"
  },
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite\"",
    "build": "vite build",
    "start": "node server/index.js --serve",
    "preview": "vite preview",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null; chmod +x node_modules/node-pty/prebuilds/darwin-x64/spawn-helper 2>/dev/null; true"
  },
  "dependencies": {
    "@linear/sdk": "^19.0.0",
    "@octokit/rest": "^20.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "express": "^4.18.3",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "ora": "^8.0.0",
    "pdf-parse": "^1.1.1",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@reactflow/core": "^11.11.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "lucide-react": "^0.395.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-flow-renderer": "^10.3.17",
    "reactflow": "^11.11.4",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "zustand": "^4.5.4"
  }
}
